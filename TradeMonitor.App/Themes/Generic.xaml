<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:TradeMonitor.App.Controls">

    <Style TargetType="{x:Type controls:StatusBadge}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:StatusBadge}">
                    <Border x:Name="BadgeBorder"
                            Padding="10,4"
                            CornerRadius="12"
                            Background="{StaticResource SecondaryBrush}">
                        <TextBlock x:Name="BadgeText"
                                   Text="{TemplateBinding Status}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Status" Value="Approved">
                            <Setter TargetName="BadgeBorder" Property="Background" Value="{StaticResource SuccessBrush}" />
                        </Trigger>

                        <Trigger Property="Status" Value="Pending">
                            <Setter TargetName="BadgeBorder" Property="Background" Value="{StaticResource WarningBrush}" />
                        </Trigger>

                        <Trigger Property="Status" Value="Rejected">
                            <Setter TargetName="BadgeBorder" Property="Background" Value="{StaticResource DangerBrush}" />
                        </Trigger>

                        <Trigger Property="Status" Value="New">
                            <Setter TargetName="BadgeBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
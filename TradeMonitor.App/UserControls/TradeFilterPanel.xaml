<UserControl x:Class="TradeMonitor.App.UserControls.TradeFilterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="120"
             d:DesignWidth="900">
    <Border Padding="12"
            Margin="0,0,0,10"
            CornerRadius="6"
            BorderBrush="{StaticResource BorderBrushTheme}"
            BorderThickness="1"
            Background="{StaticResource PanelAltBackgroundBrush}">
        <StackPanel>
            <TextBlock Text="Trade Filters"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <WrapPanel VerticalAlignment="Center">
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Search" Margin="0,0,0,4"/>
                    <TextBox Width="220"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Status" Margin="0,0,0,4"/>
                    <ComboBox Width="140"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              VerticalContentAlignment="Center"
                              VerticalAlignment="Center"
                              Padding="4,2" />
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Asset Class" Margin="0,0,0,4"/>
                    <ComboBox Width="140"
                              ItemsSource="{Binding AssetClassOptions}"
                              SelectedItem="{Binding SelectedAssetClass}"
                              VerticalContentAlignment="Center"
                              VerticalAlignment="Center"
                              Padding="4,2" />
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Sort By" Margin="0,0,0,4"/>
                    <ComboBox Width="180"
                              ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSortOption}"
                              VerticalContentAlignment="Center"
                              VerticalAlignment="Center"
                              Padding="4,2" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                    <Button Content="Load Trades"
                            Width="110"
                            Margin="0,0,10,0"
                            Command="{Binding LoadTradesCommand}" />

                    <Button Content="Apply Filter"
                            Width="110"
                            Margin="0,0,10,0"
                            Command="{Binding FilterTradesCommand}" />

                    <Button Content="Save To DB"
                            Width="110"
                            Margin="0,0,10,0"
                            Command="{Binding SaveTradesToDatabaseCommand}" />

                    <Button Content="Load From DB"
                            Width="120"
                            Margin="0,0,10,0"
                            Command="{Binding LoadTradesFromDatabaseCommand}" />

                    <Button Content="Save Config"
                        Width="110"
                        Margin="0,0,10,0"
                        Command="{Binding SaveConfigCommand}" />

                    <Button Content="Load Config"
                        Width="110"
                        Margin="0,0,10,0"
                        Command="{Binding LoadConfigCommand}" />

                    <Button Content="Analyse Selected"
                            Width="130"
                            Command="{Binding AnalyseTradesCommand}" />
                </StackPanel>
            </WrapPanel>
        </StackPanel>
    </Border>
</UserControl>
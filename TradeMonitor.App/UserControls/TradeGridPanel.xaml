<UserControl x:Class="TradeMonitor.App.UserControls.TradeGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="900">
    <Border Padding="12"
            Margin="0,0,10,0"
            CornerRadius="6"
            BorderBrush="{StaticResource BorderBrushTheme}"
            BorderThickness="1"
            Background="{StaticResource PanelBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Trades"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding FilteredTrades}"
                      SelectedItem="{Binding SelectedTrade}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      CanUserSortColumns="False"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Trade ID" Binding="{Binding TradeId}" Width="*" />
                    <DataGridTextColumn Header="Book" Binding="{Binding Book}" Width="*" />
                    <DataGridTextColumn Header="Counterparty" Binding="{Binding Counterparty}" Width="*" />
                    <DataGridTextColumn Header="Asset Class" Binding="{Binding AssetClass}" Width="*" />
                    <DataGridTextColumn Header="Trade Date" Binding="{Binding TradeDate, StringFormat=d}" Width="*" />
                    <DataGridTextColumn Header="Notional" Binding="{Binding Notional, StringFormat=N0}" Width="*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                    <DataGridTextColumn Header="Trader" Binding="{Binding Trader}" Width="*" />
                    <DataGridTextColumn Header="Region" Binding="{Binding Region}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
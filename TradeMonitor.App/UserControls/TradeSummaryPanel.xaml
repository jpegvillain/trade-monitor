<UserControl x:Class="TradeMonitor.App.UserControls.TradeSummaryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="120"
             d:DesignWidth="900">
    <Border Padding="12"
            Margin="0,0,0,10"
            CornerRadius="6"
            BorderBrush="{StaticResource BorderBrushTheme}"
            BorderThickness="1"
            Background="{StaticResource PanelBackgroundBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Total Trades"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding TotalTradesCount}"
                           FontSize="20"
                           FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Approved Trades"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ApprovedTradesCount}"
                           FontSize="20"
                           FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Total Notional"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding TotalNotional, StringFormat=N0}"
                           FontSize="20"
                           FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Grid.Column="3">
                <TextBlock Text="Largest Trade"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding LargestTradeId}"
                           FontSize="20"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>